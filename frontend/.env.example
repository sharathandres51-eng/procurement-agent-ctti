# ── API base URL ──────────────────────────────────────────────────────────────
# Development: leave unset — Vite proxies /api → localhost:8000
# Production:  set to your Railway deployment URL (no trailing slash)
# VITE_API_URL=https://your-project.railway.app

# ── Password protection ───────────────────────────────────────────────────────
# Set in the Vercel dashboard (not in this file — never commit secrets).
# The Edge Middleware compares the browser-entered password against this value.
# BASIC_AUTH_PASSWORD=your_password_here
